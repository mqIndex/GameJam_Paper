[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/views/shop/shop_buy_panel.gd" id="1_script"]

[node name="ShopBuyPanel" type="ScrollContainer"]
script = ExtResource("1_script")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="LblHint" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 15
theme_override_colors/font_color = Color(0.604, 0.655, 0.753, 1)
text = "选择一张卡牌加入牌组:"

[node name="Grid" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 10
alignment = 1

[node name="LblEmpty" type="Label" parent="Margin/VBox"]
visible = false
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.604, 0.655, 0.753, 1)
horizontal_alignment = 1
text = "(本日商品已全部售出)"
