[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/views/shop/shop_talent_panel.gd" id="1_script"]

[node name="ShopTalentPanel" type="ScrollContainer"]
script = ExtResource("1_script")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="LblHint" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 15
theme_override_colors/font_color = Color(0.604, 0.655, 0.753, 1)
text = "天赋仅在第 1 天的盘后商店上架; 跨天保留, 不再刷新。"

[node name="LblOwnedTitle" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(1, 0.682, 0.259, 1)
text = "已拥有的天赋"

[node name="OwnedGrid" type="GridContainer" parent="Margin/VBox"]
layout_mode = 2
size_flags_horizontal = 4
columns = 8
theme_override_constants/h_separation = 14
theme_override_constants/v_separation = 14

[node name="LblOwnedEmpty" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.604, 0.655, 0.753, 1)
horizontal_alignment = 1
text = "(尚未拥有任何天赋)"

[node name="Sep" type="HSeparator" parent="Margin/VBox"]
layout_mode = 2

[node name="LblOfferTitle" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(1, 0.682, 0.259, 1)
text = "可购买"

[node name="Grid" type="GridContainer" parent="Margin/VBox"]
layout_mode = 2
size_flags_horizontal = 4
columns = 8
theme_override_constants/h_separation = 14
theme_override_constants/v_separation = 14

[node name="LblOfferEmpty" type="Label" parent="Margin/VBox"]
visible = false
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.604, 0.655, 0.753, 1)
horizontal_alignment = 1
text = "(本商店无可购天赋)"
